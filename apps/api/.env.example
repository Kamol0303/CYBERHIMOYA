# Cyber Guardian AI — local env example
CGA_DATABASE_URL=sqlite:///./data/cga.db
# CGA_DATABASE_URL=postgresql://cga:cga@127.0.0.1:5432/cga
CGA_SECRET_KEY=dev-only-change-me
# chrome-extension://* → allow_origin_regex (needed for MV3 popup fetch)
CGA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,chrome-extension://*
CGA_GUEST_RATE_LIMIT_PER_HOUR=20
CGA_PUBLIC_BASE_URL=http://127.0.0.1:8000
CGA_FEED_VERSION=20260710.2
# CGA_FEED_PRIVATE_KEY_B64=...  # production only; dev key ships in app/data/keys/
# Emergency (AQ-039). Leave PENDING to force dry-run.
CGA_EMERGENCY_DRY_RUN=true
CGA_EMERGENCY_SMS_ALLOWLIST=PENDING_AQ039
CGA_EMERGENCY_API_ALLOWLIST=PENDING_AQ039
CGA_EMERGENCY_EMAIL_ALLOWLIST=PENDING_AQ039
