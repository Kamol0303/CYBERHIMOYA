<Window x:Class="CyberGuardian.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber Guardian AI"
        Height="640" Width="960"
        Background="#F7F3EA">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Cyber Guardian AI"
               FontSize="36" FontWeight="Bold"
               Foreground="{StaticResource BgDeep}"
               Margin="0,0,0,8"/>

    <TextBlock Grid.Row="1"
               Text="O‘zbekiston uchun mudofaa xavfsizlik skaneri"
               FontSize="16"
               Foreground="{StaticResource Muted}"
               Margin="0,0,0,16"/>

    <DockPanel Grid.Row="2" LastChildFill="True" Margin="0,0,0,12">
      <Button x:Name="ScanButton"
              Content="Tekshirish"
              DockPanel.Dock="Right"
              Padding="16,10"
              Background="{StaticResource Accent}"
              Foreground="White"
              BorderThickness="0"
              Click="OnScanClick"/>
      <TextBox x:Name="UrlBox"
               Padding="10"
               VerticalContentAlignment="Center"
               Margin="0,0,12,0"/>
    </DockPanel>

    <Border Grid.Row="3" Padding="16" Background="#66FFFFFF">
      <StackPanel>
        <TextBlock x:Name="ResultTitle" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBlock x:Name="ResultBody" TextWrapping="Wrap" Foreground="{StaticResource Ink}"/>
      </StackPanel>
    </Border>

    <TextBlock Grid.Row="4"
               Margin="0,12,0,0"
               Foreground="{StaticResource Muted}"
               Text="Defensive only · No offensive tooling"/>
  </Grid>
</Window>
